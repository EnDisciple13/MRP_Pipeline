# ==========================================
# BLUEPRINT 4.3: STAKEHOLDER EXCEL DELIVERABLE
# ==========================================
import pandas as pd

def calculate_inventory_health(df_enriched):
    """
    Calculates the Dead Stock vs. Active Stock ratio.
    """
    total_capital = df_enriched["Capital_Tied_Up"].sum()
    df_enriched['6M_Fwd_Demand'] = df_enriched.groupby('SKU_ID')['Demand'].shift(-6).rolling(window=6, min_periods=1).sum().fillna(0)
    df_enriched['Dead_Stock_Units'] = (df_enriched['Locked_Inv'] - df_enriched['6M_Fwd_Demand']).clip(lower=0)
    df_enriched['Dead_Stock_Value'] = df_enriched['Dead_Stock_Units'] * df_enriched['Unit_Cost']

    total_dead_stock_value = df_enriched['Dead_Stock_Value'].sum()
    health_ratio = ((total_capital - total_dead_stock_value) / total_capital) * 100 if total_capital > 0 else 100

    df_enriched.drop(columns=['6M_Fwd_Demand', 'Dead_Stock_Units', 'Dead_Stock_Value'], inplace=True)
    return health_ratio, total_dead_stock_value

def build_executive_workbook(df_enriched, capacity_alerts_list, filename="Alpha_Exec_Report.xlsx"):
    """Compiles the metrics, action plans, and raw matrices into an executive .xlsx file."""
    print(f"Generating Enterprise Excel Handoff: {filename}...")

    # 1. Calculate Executive Metrics
    agg_capital_commitment = df_enriched["Capital_Required"].sum()
    health_grade, dead_stock = calculate_inventory_health(df_enriched)

    # 2. Filter the 90-Day Action Plan
    df_action_plan = df_enriched[(df_enriched["Planned_Releases"] > 0) & (df_enriched.groupby("SKU_ID").cumcount() < 3)]

    # ==========================================
    # LOGIC UPGRADE: CONDENSING ALERTS & FIXES
    # ==========================================

    # 3A. Condense Capacity Alerts (String Parsing strategy)
    condensed_capacity_alerts = []
    if capacity_alerts_list:
        alert_counts = {}
        for alert in capacity_alerts_list:
            # Splits: "🚨 CAPACITY BREACH | SKU_001 in Month 5 | Required..."
            parts = alert.split(" | ")
            if len(parts) >= 2:
                sku_segment = parts[1] # Extracts "SKU_001 in Month 5"
                sku = sku_segment.split(" in ")[0] # Isolates "SKU_001"
                alert_counts[sku] = alert_counts.get(sku, 0) + 1
            else:
                alert_counts[alert] = alert_counts.get(alert, 0) + 1

        for sku, count in alert_counts.items():
            if count > 1:
                condensed_capacity_alerts.append(f"🚨 CAPACITY BREACH | {sku} | {count} Occurrences across 24-month horizon")
            else:
                # If it only happened once, find and print the exact original string with full detail
                original_alert = next(a for a in capacity_alerts_list if sku in a)
                condensed_capacity_alerts.append(original_alert)

    # 3B. Condense Magic Fixes (Pandas Aggregation strategy)
    df_magic_fixes = df_enriched[df_enriched["Order_Type"] == "🚨 MAGIC FIX (Past Due)"]
    condensed_magic_fixes = []

    if not df_magic_fixes.empty:
        # Group by SKU to count occurrences and sum the total receipt quantities moved to Day 0
        grouped_fixes = df_magic_fixes.groupby('SKU_ID').agg(
            Count=('Date_Index', 'count'),
            Total_Qty=('Planned_Receipts', 'sum')
        ).reset_index()

        for _, row in grouped_fixes.iterrows():
            if row['Count'] > 1:
                condensed_magic_fixes.append(f"🚨 EXPEDITE | {row['SKU_ID']} | {row['Count']} Occurrences | Total Qty Forced to Day 0: {row['Total_Qty']}")
            else:
                condensed_magic_fixes.append(f"🚨 EXPEDITE | {row['SKU_ID']} | 1 Occurrence | Qty Forced to Day 0: {row['Total_Qty']}")

    # ==========================================
    # WORKBOOK GENERATION
    # ==========================================
    writer = pd.ExcelWriter(filename, engine='xlsxwriter')
    workbook = writer.book

    header_format = workbook.add_format({'bold': True, 'font_size': 14, 'bottom': 2})
    money_format = workbook.add_format({'num_format': '$#,##0'})
    percent_format = workbook.add_format({'num_format': '0.0%'})

    ws_exec = workbook.add_worksheet("Executive Summary")

    ws_exec.write("A1", "Alpha Engine: 24-Month Master Resource Plan", header_format)
    ws_exec.write("A3", "Aggregate Capital Commitment (PO Values):")
    ws_exec.write("B3", agg_capital_commitment, money_format)
    ws_exec.write("A4", "Inventory Health Grade (Active vs Dead):")
