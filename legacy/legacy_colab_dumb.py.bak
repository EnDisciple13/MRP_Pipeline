import pandas as pd

# ==========================================
# BLUEPRINT 5: STATE INHERITANCE & TIME SHIFT
# ==========================================

def advance_rolling_horizon(alpha_calendar_array):
    """
    Blueprint 5.2: The Calendar Tick.
    Drops the month that just passed and calculates the next month to maintain the 24-period horizon.
    """
    print("Executing Time Shift: Rolling Calendar Forward...")

    last_month = pd.to_datetime(alpha_calendar_array[-1])
    next_month = last_month + pd.DateOffset(months=1)
    beta_calendar = alpha_calendar_array[1:] + [next_month.strftime('%Y-%m')]

    return beta_calendar

def extract_inherited_state(df_alpha_enriched, master_data, alpha_demand):
    """
    Blueprint 5.1 & 5.3: The Baseline Lock and Pipeline Reconciliation.
    UPGRADED: Enforces the Lead Time Fence to ensure only strictly required orders become Firmed POs.
    """
    print("Executing Baseline Lock: Inheriting Day 0 State (Time Fence Enabled)...")

    dict_beta_initial_state = {}
    dict_beta_master_data = {}
    dict_beta_demand = {}

    sku_list = df_alpha_enriched["SKU_ID"].unique()

    for sku in sku_list:
        df_sku = df_alpha_enriched[df_alpha_enriched["SKU_ID"] == sku].reset_index(drop=True)

        # --- 1. Master Data Inheritance ---
        lt = master_data[sku]["LT"]
        dict_beta_master_data[sku] = {
            "LT": lt,
            "SS": master_data[sku]["SS"],
            "MOQ": master_data[sku]["MOQ"],
            "Max_Cap": master_data[sku]["Max_Cap"],
            "Unit_Cost": master_data[sku]["Unit_Cost"],
            "Unit_Revenue": master_data[sku]["Unit_Revenue"],
            "Status": master_data[sku]["Status"],
            "Lifecycle_Status": "Active"
        }

        # --- 2. Baseline Lock ---
        # Grab the final Locked_Inv from Month 1 (Index 0). This becomes the unalterable I_0.
        locked_inv_month_1 = df_sku.loc[0, "Locked_Inv"]

        # --- 3. Pipeline Reconciliation (The Time Fence Patch) ---
        alpha_planned_receipts = df_sku["Planned_Receipts"].tolist()
        shifted_planned = alpha_planned_receipts[1:] + [0]

        beta_firmed_receipts = []
        for i in range(24):
            # If the arrival falls within the Lead Time, the order was already released in Day 0.
            # It is legally committed. We lock it as FIRM.
            if i < lt:
                beta_firmed_receipts.append(shifted_planned[i])
            # If the arrival is outside the Lead Time, it was just a Ghost.
            # It is NOT firmed, leaving the Beta Engine free to optimize.
            else:
                beta_firmed_receipts.append(0)

        dict_beta_initial_state[sku] = {
            "On_Hand": locked_inv_month_1,
            "Firmed_Receipts_Array": beta_firmed_receipts
        }

        # --- 4. Demand Array Shift ---
        current_demand = alpha_demand[sku]
        dict_beta_demand[sku] = current_demand[1:] + [current_demand[-1]]

    return dict_beta_initial_state, dict_beta_master_data, dict_beta_demand

# ==========================================
# SYSTEM EXECUTION
# ==========================================

