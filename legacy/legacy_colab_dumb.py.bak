import pandas as pd
import math

# ==========================================
# BLUEPRINT 1: ENTERPRISE DATA GENERATION
# ==========================================

# 1. Static Master Data (The Rules)
# Max_Cap adjusted to realistic constraints to force Phase II bottlenecks. Unit_Cost added for Phase III financial vectorization.
CONSTRAINTS = {
    "SKU_001": {"LT": 1, "SS": 20, "MOQ": 1,  "Max_Cap": 40,  "Unit_Cost": 50.00,  "Unit_Revenue": 200.00,  "Status": "Active"},
    "SKU_002": {"LT": 2, "SS": 10, "MOQ": 1,  "Max_Cap": 80,  "Unit_Cost": 120.00, "Unit_Revenue": 500.00,  "Status": "Active"},
    "SKU_003": {"LT": 1, "SS": 20, "MOQ": 10, "Max_Cap": 100, "Unit_Cost": 15.00,  "Unit_Revenue": 150.00,  "Status": "Active"},
    "SKU_004": {"LT": 1, "SS": 0,  "MOQ": 1,  "Max_Cap": 30,  "Unit_Cost": 10.00,  "Unit_Revenue": 50.00,   "Status": "Phasing_Out"},
    "SKU_005": {"LT": 1, "SS": 5,  "MOQ": 50, "Max_Cap": 150, "Unit_Cost": 5.00,   "Unit_Revenue": 35.00,   "Status": "Active"},
    "SKU_006": {"LT": 2, "SS": 20, "MOQ": 1,  "Max_Cap": 200, "Unit_Cost": 75.00,  "Unit_Revenue": 300.00,  "Status": "Phasing_In"},
    "SKU_007": {"LT": 1, "SS": 50, "MOQ": 1,  "Max_Cap": 300, "Unit_Cost": 200.00, "Unit_Revenue": 1200.00, "Status": "Active"}
}

# 2. Dynamic State Data (The Reality)
INVENTORY = {
    "SKU_001": {"On_Hand": 100, "Open_PO": 0,  "PO_Month_Index": 0},
    "SKU_002": {"On_Hand": 10,  "Open_PO": 50, "PO_Month_Index": 3},
    "SKU_003": {"On_Hand": 50,  "Open_PO": 0,  "PO_Month_Index": 0},
    "SKU_004": {"On_Hand": 150, "Open_PO": 0,  "PO_Month_Index": 0},
    "SKU_005": {"On_Hand": 0,   "Open_PO": 0,  "PO_Month_Index": 0},
    "SKU_006": {"On_Hand": 0,   "Open_PO": 0,  "PO_Month_Index": 0},
    "SKU_007": {"On_Hand": 20,  "Open_PO": 0,  "PO_Month_Index": 0}
}

# 3. The 24-Month Demand Arrays
# SKU_007 adjusted to correctly represent the "2-Time Capacity Breaker" archetype.
DEMAND = {
    "SKU_001": [10] * 24,
    "SKU_002": [20] * 24,
    "SKU_003": ([10] * 6) + [500] + ([10] * 17),
    "SKU_004": ([5] * 6) + [0] * 18,
    "SKU_005": [12] * 24,
    "SKU_006": ([0] * 3) + [50] * 21,
    "SKU_007": ([20] * 6) + [1000] + ([20] * 6) + [1000] + ([20] * 10)
}

# 4. Absolute Calendar Indexing Engine
def generate_calendar_horizon(start_date="2026-06-01", periods=24):
    """Generates the absolute string array for the X-axis."""
    dates = pd.date_range(start=start_date, periods=periods, freq='MS')
    return [date.strftime('%Y-%m') for date in dates]

calendar_array = generate_calendar_horizon()
print(f"✅ Data Generation Suite Initialized. Horizon anchored at: {calendar_array[0]}")

# ==========================================
# BLUEPRINT 2: PATH-DEPENDENT STATE MACHINE
# ==========================================

def execute_sku_simulation(sku_id, master_data, initial_state, demand_array, calendar_array):
    """Runs the 4-step execution loop for a single SKU over the 24-month horizon."""

    # 1. Telemetry Initialization
    locked_inv = []
    planned_receipts = []
    planned_releases = [0] * 24

    current_inv = initial_state["On_Hand"]
    ss = master_data["SS"]
    moq = master_data["MOQ"]
    lt = master_data["LT"]
    max_cap = master_data["Max_Cap"]

    # Setup Open POs (Scheduled Receipts)
    scheduled_receipts = [0] * 24
    if initial_state["Open_PO"] > 0 and initial_state["PO_Month_Index"] < 24:
        scheduled_receipts[initial_state["PO_Month_Index"]] = initial_state["Open_PO"]

    # 2. The 4-Step Execution Loop (Strictly Sequential)
    for t in range(24):
        d_t = demand_array[t]
        sr_t = scheduled_receipts[t]

        # Step 1: Unhealed Balance
        raw_balance = current_inv + sr_t - d_t
        porcpt_t = 0

        # Step 2: Evaluate Constraints
        if raw_balance < ss:
            # Step 3: Inject Unconstrained Receipt (The Arrival Fix)
            deficit = ss - raw_balance
            porcpt_t = math.ceil(deficit / moq) * moq

        # Step 4: Lock State
        current_inv = raw_balance + porcpt_t

        # Ledger Update
        locked_inv.append(current_inv)
        planned_receipts.append(porcpt_t)

    # 3. The Time-Shift & Capacity Validation (Backward Scheduling)
    capacity_alerts = []
    for t in range(24):
        receipt_qty = planned_receipts[t]
        if receipt_qty > 0:

            # 3A. The Time Shift
            release_index = t - lt
            if release_index >= 0:
                planned_releases[release_index] += receipt_qty
            else:
                # Forced Magic Fix: Lead time pushes release date into the past.
                planned_releases[0] += receipt_qty

            # 3B. Capacity Breach Check
            if receipt_qty > max_cap:
                capacity_alerts.append({
                    "Month": calendar_array[t],
                    "Required": receipt_qty,
                    "Limit": max_cap
                })

    # Package into a structured Pandas DataFrame for this specific SKU
    df_sku = pd.DataFrame({
        "SKU_ID": sku_id,
        "Date_Index": calendar_array,
        "Demand": demand_array,
        "Scheduled_Receipts": scheduled_receipts,
        "Planned_Receipts": planned_receipts,
        "Planned_Releases": planned_releases,
        "Locked_Inv": locked_inv
    })

    return df_sku, capacity_alerts

# ==========================================
# SYSTEM EXECUTION & FILE EXPORT
# ==========================================

print("Initializing Alpha Engine State Machine...")
all_sku_dfs = []
all_alerts = []

# Loop through the portfolio archetype
for sku in CONSTRAINTS.keys():
    df, alerts = execute_sku_simulation(
        sku,
        CONSTRAINTS[sku],
        INVENTORY[sku],
        DEMAND[sku],
        calendar_array
    )
    all_sku_dfs.append(df)

    for alert in alerts:
        all_alerts.append(f"🚨 CAPACITY BREACH | {sku} in {alert['Month']} | Required: {alert['Required']} vs Limit: {alert['Limit']}")

# Fuse all independent SKUs into the master Enterprise DataFrame
df_enterprise_matrix = pd.concat(all_sku_dfs, ignore_index=True)

# Output strictly to the Colab Filesystem
output_filename = "Alpha_Raw_Horizon.csv"
df_enterprise_matrix.to_csv(output_filename, index=False)

print("\n--- Simulation Complete ---")
print(f"Master Matrix generated successfully with {len(df_enterprise_matrix)} rows.")
print(f"✅ Data saved to Colab workspace as: '{output_filename}'")

# Print the bleeding edges caught by the capacity checker
print("\n--- Capacity Alerts Detected ---")
if not all_alerts:
    print("None detected.")
else:
    for alert in all_alerts:
        print(alert)

# ==========================================
# BLUEPRINT 3: THE BASELINE ORGANIZER (UPGRADED)
# ==========================================
import pandas as pd
import numpy as np

def enrich_baseline_matrix(df_raw, master_data):
    df = df_raw.copy()

    # 1. Map Master Data Scalars
    unit_cost_map = {sku: data["Unit_Cost"] for sku, data in master_data.items()}
    unit_rev_map = {sku: data["Unit_Revenue"] for sku, data in master_data.items()} # NEW
    ss_map = {sku: data["SS"] for sku, data in master_data.items()}
    lt_map = {sku: data["LT"] for sku, data in master_data.items()}
    max_cap_map = {sku: data["Max_Cap"] for sku, data in master_data.items()}

    df["Unit_Cost"] = df["SKU_ID"].map(unit_cost_map)
    df["Unit_Revenue"] = df["SKU_ID"].map(unit_rev_map) # NEW
    df["Target_SS"] = df["SKU_ID"].map(ss_map)
    df["Lead_Time"] = df["SKU_ID"].map(lt_map)
    df["Max_Cap"] = df["SKU_ID"].map(max_cap_map)

    df["Month_Index"] = df.groupby("SKU_ID").cumcount()

    # 2. Order Classification Engine (The 4-State Tagger)
    conditions = [
        (df["Planned_Receipts"] == 0),
        (df["Planned_Receipts"] > 0) & ((df["Month_Index"] - df["Lead_Time"]) < 0),
        (df["Planned_Receipts"] > df["Max_Cap"]),
        (df["Planned_Receipts"] > 0) & ((df["Month_Index"] - df["Lead_Time"]) >= 0)
    ]
    choices = [
        "Stable",
        "🚨 MAGIC FIX (Past Due)",
        "⚠️ CAPACITY BREACH",
        "Normal Execution"
    ]
    df["Order_Type"] = np.select(conditions, choices, default="Unknown")

    # 3. The Financial Scorecard
    df["Capital_Tied_Up"] = df["Locked_Inv"] * df["Unit_Cost"]
    df["Capital_Required"] = df["Planned_Receipts"] * df["Unit_Cost"]
    df["Safety_Stock_Cost"] = df["Target_SS"] * df["Unit_Cost"]

    # NEW: Calculate Revenue at Risk ONLY for exceptions
    df["Revenue_at_Risk"] = np.where(
        df["Order_Type"].isin(["🚨 MAGIC FIX (Past Due)", "⚠️ CAPACITY BREACH"]),
        df["Planned_Receipts"] * df["Unit_Revenue"],
        0
    )

    # Clean up
    df = df.drop(columns=["Month_Index", "Target_SS", "Lead_Time", "Max_Cap"])

    return df

# --- EXECUTION ---
df_alpha_enriched = enrich_baseline_matrix(df_enterprise_matrix, CONSTRAINTS)
print("✅ Baseline Matrix Enriched. Revenue at Risk calculated.")

