# 6.1 Data Structures (The Chaos Payload - Fully Upgraded)
CHAOS_PAYLOAD = [
    # --- SCENARIO 1: THE WHIP EFFECT (CRASH + SPIKE COMPOUND) ---
    # SKU_001 experiences a market crash in Aug 2026, dropping demand by 15 units/month.
    # Four months later (Dec 2026), a massive recovery hits, spiking demand by +45 units/month.
    {"SKU_ID": "SKU_001", "Mutation_Type": "Longitudinal_Demand_Shift", "Target_Date": "2026-08", "Magnitude": -15},
    {"SKU_ID": "SKU_001", "Mutation_Type": "Longitudinal_Demand_Shift", "Target_Date": "2026-12", "Magnitude": 45},

    # --- SCENARIO 2: LONGITUDINAL GROWTH ---
    # SKU_002 wins a new national contract in Sept 2026. Demand permanently increases by 15 units/month.
    {"SKU_ID": "SKU_002", "Mutation_Type": "Longitudinal_Demand_Shift", "Target_Date": "2026-09", "Magnitude": 15},

    # --- SCENARIO 3: COMPOUND OPERATIONAL CHAOS ---
    {"SKU_ID": "SKU_003", "Mutation_Type": "Demand_Shock", "Target_Date": "2026-10", "Magnitude": 500},
    {"SKU_ID": "SKU_003", "Mutation_Type": "Supply_Delay", "Target_Date": "2026-09", "Magnitude": 1},

    # --- SCENARIO 4: THE ABSOLUTE BOTTLENECK WHIP (SKU_007 TRIPLE COMPOUND) ---
    # 1. Supply Constraint: Lock the maximum capacity down to 150 units.
    {"SKU_ID": "SKU_007", "Mutation_Type": "Constraint", "Target_Variable": "Max_Cap", "Magnitude": 150},

    # 2. Initial Longitudinal Crash: Drop demand by 20 units/month immediately at start (July 2026).
    # This applies a -20 shift to months 1 through 24.
    {"SKU_ID": "SKU_007", "Mutation_Type": "Longitudinal_Demand_Shift", "Target_Date": "2026-07", "Magnitude": -20},

    # 3. Mid-Horizon Longitudinal Spike: Increase demand by +50 units/month exactly midway (July 2027).
    # This applies a +50 shift to months 13 through 24.
    # Net Result: Months 1-12 are down 20 units. Months 13-24 are up 30 units net from baseline (+50 - 20).
    {"SKU_ID": "SKU_007", "Mutation_Type": "Longitudinal_Demand_Shift", "Target_Date": "2027-07", "Magnitude": 50},

    # --- SCENARIO 5: CONSTRAINT MUTATION ---
    {"SKU_ID": "SKU_006", "Mutation_Type": "Constraint", "Target_Variable": "LT", "Magnitude": 4},

    # --- SCENARIO 6: THE ZOMBIE ---
    {"SKU_ID": "SKU_005", "Mutation_Type": "Zombie", "Target_Date": "2027-01"}
]

# 6.2 The Event Execution Engine
def apply_chaos_events(beta_initial_state, beta_master_data, beta_demand, beta_calendar, payload):
    print("Executing Blueprint 6: Injecting Chaos Payload into Day X Timeline...\n")

    for event in payload:
        sku = event["SKU_ID"]
        m_type = event["Mutation_Type"]

        # Failsafe: Ensure the SKU exists in our universe
        if sku not in beta_master_data:
            continue

        print(f"🚨 INJECTING [{m_type}] into {sku}...")

        # --- SHOCK A: DEMAND SHOCK (Single Month) ---
        if m_type == "Demand_Shock":
            target_date = event["Target_Date"]
            mag = event["Magnitude"]
            if target_date in beta_calendar:
                idx = beta_calendar.index(target_date)
                beta_demand[sku][idx] += mag
                print(f"   -> Demand at {target_date} altered by {mag} units.")

        # --- SHOCK B: LONGITUDINAL DEMAND SHIFT (Structural) ---
        elif m_type == "Longitudinal_Demand_Shift":
            target_date = event["Target_Date"]
            mag = event["Magnitude"]

            if target_date in beta_calendar:
                idx = beta_calendar.index(target_date)

                # Apply the shift to the target month AND every month after it
                for i in range(idx, 24):
                    new_demand = beta_demand[sku][i] + mag
                    # Failsafe: Demand cannot drop below 0
                    beta_demand[sku][i] = max(0, new_demand)

                print(f"   -> Structural Market Shift: Demand adjusted by {mag} from {target_date} to end of horizon.")

        # --- SHOCK C: SUPPLY DELAY ---
        elif m_type == "Supply_Delay":
            target_date = event["Target_Date"]
            delay_months = event["Magnitude"]

            if target_date in beta_calendar:
                idx = beta_calendar.index(target_date)
                firmed_array = beta_initial_state[sku]["Firmed_Receipts_Array"]

                if firmed_array[idx] > 0:
                    delayed_qty = firmed_array[idx]
                    firmed_array[idx] = 0

                    new_arrival_idx = idx + delay_months
                    if new_arrival_idx < 24:
                        firmed_array[new_arrival_idx] += delayed_qty
                        print(f"   -> Boat Delayed! {delayed_qty} units pushed from {target_date} to {beta_calendar[new_arrival_idx]}.")
                    else:
                        print(f"   -> CRITICAL: {delayed_qty} units delayed past the 24-month planning horizon. Inventory lost.")

        # --- SHOCK D: CONSTRAINT MUTATION ---
        elif m_type == "Constraint":
            var = event["Target_Variable"]
            new_val = event["Magnitude"]
            old_val = beta_master_data[sku][var]
            beta_master_data[sku][var] = new_val
            print(f"   -> Supplier parameter [{var}] mutated from {old_val} to {new_val}.")

        # --- SHOCK E: THE ZOMBIE (Product Retirement) ---
        elif m_type == "Zombie":
            target_date = event["Target_Date"]
            beta_master_data[sku]["Lifecycle_Status"] = "Zombie"

            if target_date in beta_calendar:
                idx = beta_calendar.index(target_date)
                for i in range(idx, 24):
                    beta_demand[sku][i] = 0
            print(f"   -> Product flagged for retirement. Demand zeroed out from {target_date} onward.")

    return beta_initial_state, beta_master_data, beta_demand

# ==========================================
# SYSTEM EXECUTION
# ==========================================

# We use copy.deepcopy() to ensure we don't accidentally corrupt our pristine Day 0 objects in memory!
mutated_beta_initial = copy.deepcopy(beta_initial_state)
mutated_beta_master = copy.deepcopy(beta_master_data)
mutated_beta_demand = copy.deepcopy(beta_demand)

# Execute the mutations
mutated_beta_initial, mutated_beta_master, mutated_beta_demand = apply_chaos_events(
    mutated_beta_initial,
    mutated_beta_master,
    mutated_beta_demand,
    beta_calendar_array,
    CHAOS_PAYLOAD
)
print("\n✅ Day X Matrix Successfully Mutated.")

import pandas as pd
import math

# ==========================================
# BLUEPRINT 7: THE BETA RECALCULATION ENGINE
# ==========================================

def execute_beta_run(calendar_array, master_data, initial_state, demand_dict):
    """
    Reruns the Path-Dependent State Machine on the Day X reality.
    """
    print("Initializing Beta Recalculation Engine...\n")
    all_sku_dfs = []
    beta_capacity_alerts = []

    for sku in master_data.keys():
        # 1. Telemetry Initialization
        locked_inv = []
        planned_receipts = []
        planned_releases = [0] * 24

        current_inv = initial_state[sku]["On_Hand"]
        scheduled_receipts = initial_state[sku]["Firmed_Receipts_Array"]
        demand_array = demand_dict[sku]

        # Pull the mutated constraints
        ss = master_data[sku]["SS"]
        moq = master_data[sku]["MOQ"]
        lt = master_data[sku]["LT"]
        max_cap = master_data[sku]["Max_Cap"]

        # 2. The 4-Step Execution Loop (The exact same physics)
        for t in range(24):
            d_t = demand_array[t]
            sr_t = scheduled_receipts[t]

            # Step 1: Unhealed Balance
            raw_balance = current_inv + sr_t - d_t
            porcpt_t = 0

            # Step 2: Evaluate Constraints
            if raw_balance < ss:
                # Step 3: Arrival Fix
                deficit = ss - raw_balance
                porcpt_t = math.ceil(deficit / moq) * moq

            # Step 4: Lock State
            current_inv = raw_balance + porcpt_t

            # Ledger Update
            locked_inv.append(current_inv)
            planned_receipts.append(porcpt_t)

        # 3. The Time-Shift & Capacity Validation
        for t in range(24):
            receipt_qty = planned_receipts[t]
            if receipt_qty > 0:
                release_index = t - lt

                # Check for Time-Travel Breach
                if release_index >= 0:
                    planned_releases[release_index] += receipt_qty
                else:
                    planned_releases[0] += receipt_qty # Forced Magic Fix

                # Check for Capacity Breach
                if receipt_qty > max_cap:
                    beta_capacity_alerts.append({
                        "SKU": sku,
                        "Month": calendar_array[t],
                        "Required": receipt_qty,
                        "Limit": max_cap
                    })

        # Package into DataFrame
        df_sku = pd.DataFrame({
            "SKU_ID": sku,
            "Date_Index": calendar_array,
            "Demand": demand_array,
            "Scheduled_Receipts": scheduled_receipts,
            "Planned_Receipts": planned_receipts,
            "Planned_Releases": planned_releases,
            "Locked_Inv": locked_inv
        })
        all_sku_dfs.append(df_sku)

    df_beta_raw = pd.concat(all_sku_dfs, ignore_index=True)
    return df_beta_raw, beta_capacity_alerts

# ==========================================
# SYSTEM EXECUTION & RE-ENRICHMENT
# ==========================================

# 1. Run the Beta Physics Engine
df_beta_raw, beta_alerts = execute_beta_run(
