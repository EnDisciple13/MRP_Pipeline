# BLUEPRINT 4.1: RAW DATA & COMPLETE AUDIT TRACE
# ==========================================
import pandas as pd
import os

def export_exception_log(df_enriched, filename="Alpha_Exception_Log.csv"):
    """Filters for bleeding-edge exceptions and saves them to a CSV."""
    print(f"Generating Exception Log: {filename}...")

    df_exceptions = df_enriched[df_enriched["Order_Type"] == "🚨 MAGIC FIX (Past Due)"]

    if df_exceptions.empty:
        print("✅ No critical timing exceptions detected. Log is empty.")
    else:
        action_cols = ["SKU_ID", "Date_Index", "Planned_Receipts", "Capital_Required"]
        df_exceptions[action_cols].to_csv(filename, index=False)
        print(f"🚨 Caught {len(df_exceptions)} exceptions. Saved to Colab workspace.")

def export_full_pedagogical_trace(df_enriched, master_data, months_to_trace=24, filename="Alpha_All_SKUs_Trace.txt"):
    """
    Iterates through the entire SKU portfolio, reconstructing the algebraic
    state-machine loop, and writes the master proof to a .txt file.
    """
    print(f"Generating Complete Audit Trace: {filename}...")

    # Extract unique SKUs to loop through
    sku_list = df_enriched["SKU_ID"].unique()

    with open(filename, "w") as f:
        for sku in sku_list:
            # Dynamically pull the Safety Stock target for the current SKU
            target_ss = master_data[sku]["SS"]

            f.write("=========================================\n")
            f.write(f"=== 🔍 PEDAGOGICAL TRACE: {sku} ===\n")
            f.write(f"Target Safety Stock (SS): {target_ss}\n")
            f.write("=========================================\n\n")

            df_sku = df_enriched[df_enriched["SKU_ID"] == sku].head(months_to_trace)

            # Reverse-engineer the true starting inventory (I_0)
            first_row = df_sku.iloc[0]
            prev_inv = first_row["Locked_Inv"] - first_row["Planned_Receipts"] + first_row["Demand"] - first_row["Scheduled_Receipts"]

            for index, row in df_sku.iterrows():
                t = row["Date_Index"]
                d_t = row["Demand"]
                r_t = row["Planned_Receipts"]
                sr_t = row["Scheduled_Receipts"]
                i_t = row["Locked_Inv"]

                unhealed = prev_inv + sr_t - d_t
                breach_flag = "⚠️ BREACH" if unhealed < target_ss else "✅ STABLE"

                # Write the exact math logic to the file
                f.write(f"Month: {t}\n")
                f.write(f"  1. Raw Balance  -> {prev_inv} (I_t-1) + {sr_t} (SR_t) - {d_t} (D_t) = {unhealed}\n")
                f.write(f"  2. Constraint   -> {unhealed} < {target_ss} ? {breach_flag}\n")

                # --- THE CORRECTION IS HERE ---
                if unhealed < target_ss:
                    f.write(f"  3. Arrival Fix  -> Injecting {r_t} (R_t) to heal timeline.\n")
                # ------------------------------

                f.write(f"  4. Locked State -> {i_t} (I_t passed to next month)\n\n")

                prev_inv = i_t

        f.write("END OF MASTER AUDIT TRACE\n")
    print("✅ Master Trace written successfully. Saved to Colab workspace.")

# --- EXECUTION ---
export_exception_log(df_alpha_enriched, filename="Alpha_Exception_Log.csv")

# Passing the CONSTRAINTS dict so the function can find the SS rules for every SKU
export_full_pedagogical_trace(df_alpha_enriched, CONSTRAINTS, months_to_trace=24, filename="Alpha_All_SKUs_Trace.txt")

